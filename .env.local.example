# Live Google-Bewertungen (Places API New)
# Setup: Google Cloud Console → „Places API (New)" aktivieren → API-Key
# Place ID finden:  GOOGLE_PLACES_API_KEY=... node scripts/find-place-id.mjs
# Ohne diese Variablen zeigt die Website kuratierte Fallback-Bewertungen.
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
